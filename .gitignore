# ============================================================
# AI Workspace Standards — .gitignore
# This repo tracks ONLY workspace-level config files.
# All project subdirectories are independent git repos.
# ============================================================

# --- Ignore all subdirectories (each is its own project, not tracked here) ---
# Workspace Root tracks ONLY: scripts/, templates/, agents/, docs/, skills/,
# memory/, and root-level config files. All other subdirectories are excluded.
/*/

# --- PM gateway approval flag (session-local, must not be committed) ---
.pm-approved

# --- dev-sync pipeline temp files ---
CHANGELOG_ENTRY.md
.sync_context.tmp
.sync_context.*.tmp

# --- Secrets and local certs ---
.env
*.pem
*.key
*.cmd
*.p12
*.pfx
*.jks
id_rsa*
id_ed25519*
*.cert
*.crt
credentials.json
*_credentials*
.env.*.local

# --- Node (workspace-level package.json artifacts) ---
node_modules/
package-lock.json

# --- OS artifacts ---
.DS_Store
Thumbs.db
Desktop.ini

# --- IDE ---
.idea/
.vscode/
*.swp
*.swo

# --- Python compiled ---
__pycache__/
*.pyc
*.pyo

# --- Claude local settings (personal, not shared) ---
.claude/settings.local.json
# --- Claude Code worktrees (ephemeral, agent-created) ---
.claude/worktrees/

# --- Explicitly TRACK these workspace-level files ---
# (gitignore negations — override the /*/  rule above)
!CLAUDE.md
!GEMINI.md
!CONSTITUTION.md
!CHANGELOG.md
!README.md
!LICENSE
!.gitignore
!.githooks/
!.claude/
!.gemini/
!.agents/
!scripts/
!templates/
!.editorconfig
!SECURITY.md
!AGENTS.md
!agents/
!memory/
!.github/
!docs/
!docs/constitution/
!docs/governance/
!docs/lifecycle/
!docs/designs/
!skills/
!templates/common/
!templates/co-consult/
!templates/co-design/
!templates/co-develop/
!templates/co-security/
!templates/co-work/

# --- CodeGraph Index ---
.codegraph/
nul
NUL

# --- Sandbox for testing ---
.sandbox/

# Scaffolding test output (generated by scripts/test-new-project.ts)
test-*/

# External projects (not part of ai-workspace-standards)
co-deck2

# Archive directory ignored to save space (local preservation only)
memory/archive/

# Ignore test temp directories
tests/.temp/
