{
  "mcpServers": {
    "codegraph": {
      "command": "npx",
      "args": [
        "-y",
        "@colbymchenry/codegraph",
        "serve"
      ]
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "git config core.hooksPath .githooks",
        "statusMessage": "Configuring git hooks..."
      }
    ]
  }
}