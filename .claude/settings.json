{
  "effortLevel": "high",
  "permissions": {
    "allow": [
      "Bash(bun scripts/audit.ts *)",
      "Bash(bun scripts/lifecycle-sync-audit.ts *)",
      "Bash(bun run agent:verify *)",
      "Bash(curl -sI *)",
      "Bash(bun scripts/validate-templates.ts *)",
      "WebSearch(*)",
      "WebFetch(*)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push --force-with-lease*)",
      "Bash(*--no-verify*)",
      "Bash(rm -rf *)"
    ]
  },
  "mcpServers": {
    "codegraph": {
      "command": "npx",
      "args": [
        "@colbymchenry/codegraph@1.0.1",
        "serve",
        "--mcp"
      ]
    }
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "teammateMode": "auto",
  "worktree": {
    "bgIsolation": "none"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bun scripts/hooks/post-write-lifecycle-check.ts",
            "timeout": 60,
            "async": true,
            "asyncRewake": true,
            "statusMessage": "Running post-edit lifecycle check..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "git config core.hooksPath .githooks",
            "async": true,
            "statusMessage": "Configuring git hooks..."
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bun scripts/hooks/post-write-lifecycle-check.ts",
            "timeout": 60,
            "async": true,
            "asyncRewake": true,
            "statusMessage": "Running teammate idle lifecycle check..."
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bun scripts/audit.ts",
            "timeout": 120,
            "async": true,
            "statusMessage": "Running QA audit on task completion..."
          }
        ]
      }
    ],
    "WorktreeCreate": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "git config core.hooksPath .githooks",
            "async": true,
            "statusMessage": "Configuring git hooks in new worktree..."
          }
        ]
      }
    ]
  }
}