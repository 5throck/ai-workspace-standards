{
  "type": "module",
  "name": "ai-workspace-scripts",
  "version": "1.0.0",
  "description": "AI Workspace - Utility scripts for template maintenance and agent management",
  "scripts": {
    "test": "bun scripts/test-runner.ts integration",
    "test:unit": "bun scripts/test-runner.ts unit",
    "test:e2e": "bun scripts/test-runner.ts scenarios",
    "test:full": "bun scripts/test-runner.ts scenarios && bun scripts/test-runner.ts integration && bun scripts/test-runner.ts unit",
    "verify-skills": "bun scripts/verify-skills.ts",
    "validate-agents": "bun scripts/validate-agents.ts",
    "validate-doc-folder": "bun scripts/validate-doc-folder.ts",
    "validate-skills": "bun scripts/validate-skills.ts",
    "validate:language": "bun scripts/validate-md-language.ts",
    "agent:create": "bun scripts/agent-create.ts",
    "agent:list": "bun scripts/agent-list.ts",
    "agent:delete": "bun scripts/agent-delete.ts",
    "agent:verify": "bun scripts/agent-verify.ts",
    "dispatch:parallel": "bun scripts/dispatch.ts parallel",
    "dispatch:serial": "bun scripts/dispatch.ts serial",
    "audit": "bun scripts/audit.ts",
    "dev-sync": "bun scripts/dev-sync.ts",
    "sync-md": "bun scripts/sync-md.ts",
    "gen-pr-body": "bun scripts/gen-pr-body.ts",
    "qa-gate": "bun scripts/qa-gate.ts",
    "publish-to-template": "bun scripts/publish-to-template.ts",
    "list-template-versions": "bun scripts/list-template-versions.ts",
    "sync-skills": "bun scripts/sync-skills.ts",
    "agent-lifecycle-audit": "bun scripts/agent-lifecycle-audit.ts",
    "skill-lifecycle-audit": "bun scripts/skill-lifecycle-audit.ts",
    "readme-lifecycle-audit": "bun scripts/readme-lifecycle-audit.ts",
    "lifecycle-sync": "bun scripts/lifecycle-sync-audit.ts",
    "propagate": "bun scripts/propagate-to-templates.ts",
    "validate-templates": "bun scripts/validate-templates.ts",
    "version-manifest": "bun scripts/generate-version-manifest.ts",
    "translate-readme": "bun scripts/translate-readme.ts",
    "verify-scripts": "bun scripts/verify-scripts.ts",
    "clean:sandbox": "bun -e \"import {rmSync, mkdirSync} from 'node:fs'; rmSync('.sandbox', {recursive:true, force:true}); mkdirSync('.sandbox');\""
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "glob": "^11.0.0",
    "js-yaml": "^4.1.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "workspace-scripts": true
}
