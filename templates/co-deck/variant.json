    "statusSince": "2026-06-17",
    "lastTransition": "initial → beta on 2026-06-17",
    "stablePromotedOn": null
  },
  "agents": [
    { "name": "version",       "file": "agents/version.md" },
    { "name": "research",      "file": "agents/research.md" },
    { "name": "storyline",     "file": "agents/storyline.md" },
    { "name": "design",        "file": "agents/design.md" },
    { "name": "image-curator", "file": "agents/image-curator.md" },
    { "name": "html-build",    "file": "agents/html-build.md" },
    { "name": "measure",       "file": "agents/measure.md" },
    { "name": "pdf-export",    "file": "agents/pdf-export.md" }
  ],
  "agent_manifest": {
    "variant_agents_dir": "agents",
    "pipeline_order": [
