{
  "name": "co-deck",
  "description": "Lecture and presentation material production variant — 11-stage AI workflow from research to print-ready PDF. Includes 9 specialized agents covering research, source verification, content, design, image curation, HTML build (4 themes), layout measurement, and PDF export.",
  "variant_type": "lecture",
  "status": "beta",
  "version": "0.1.0",
  "inherits_common": "templates/common",
  "created_at": "2026-06-17T08:35:00.906Z",
  "lifecycle": {
    "statusSince": "2026-06-17",
    "lastTransition": "initial → beta on 2026-06-17",
    "stablePromotedOn": null
  },
  "agents": [
    { "name": "version",          "file": "agents/version.md" },
    { "name": "research",         "file": "agents/research.md" },
    { "name": "source-verifier",  "file": "agents/source-verifier.md" },
    { "name": "storyline",        "file": "agents/storyline.md" },
    { "name": "design",           "file": "agents/design.md" },
    { "name": "image-curator",    "file": "agents/image-curator.md" },
    { "name": "html-build",       "file": "agents/html-build.md" },
    { "name": "measure",          "file": "agents/measure.md" },
    { "name": "pdf-export",       "file": "agents/pdf-export.md" }
  ],
  "agent_manifest": {
    "variant_agents_dir": "agents",
    "pipeline_order": [
      "version", "research", "source-verifier", "storyline", "design",
      "image-curator", "html-build", "measure", "pdf-export"
    ],
    "optional": ["source-verifier", "image-curator"],
    "notes": "source-verifier: skip with --skip-verify flag for draft iterations. image-curator: skip if all slides use image_role: none or images are pre-supplied."
  },
  "skills": [
    { "name": "version" },
    { "name": "research" },
    { "name": "storyline" },
    { "name": "design" },
    { "name": "html-build" },
    { "name": "measure" },
    { "name": "pdf-export" }
  ],
  "script_manifest": {
    "variant_scripts_dir": "scripts/co-deck",
    "local": [
      { "name": "snapshot",       "path": "scripts/co-deck/snapshot.ts" },
      { "name": "download-font",  "path": "scripts/co-deck/download-font.ts" },
      { "name": "gen-slides-pdf", "path": "scripts/co-deck/gen-slides-pdf.ts" },
      { "name": "measure-layout", "path": "scripts/co-deck/measure-layout.ts" }
    ],
    "external": []
  },
  "theme_manifest": {
    "themes_dir": "html-themes",
    "base_css": "html-themes/base/base.css",
    "available": ["classic", "minimal", "visual-heavy", "academic"],
    "default": "classic",
    "overrides_dir": "html-themes/overrides",
    "notes": "CSS variable override themes. DOM structure is immutable across all themes. visual-heavy requires renderSlide() data-theme detection for background-image injection."
  },
  "lecture_profile": {
    "template_path": "docs/lecture-profile.md",
    "required_fields": ["title", "audience", "level"],
    "notes": "Scaffolded on new-project creation. Agents load this file at stage start."
  }
}