{
  "type": "module",
  "name": "co-deck-project",
  "private": true,
  "description": "co-deck variant project — AI-assisted lecture slide production",
  "scripts": {
    "download-font": "bun scripts/co-deck/download-font.ts",
    "extract-slidedata": "bun scripts/extract_slidedata.mjs",
    "measure-layout": "bun scripts/co-deck/measure-layout.ts",
    "gen-pdf": "bun scripts/co-deck/gen-slides-pdf.ts",
    "auto-calibrate": "bun scripts/co-deck/auto-calibrate.ts",
    "snapshot": "bun scripts/co-deck/snapshot.ts",
    "audit": "bun scripts/audit.ts",
    "dev-sync": "bun scripts/dev-sync.ts",
    "sync-md": "bun scripts/sync-md.ts",
    "test": "bun test",
    "test:smoke": "bun test scripts/co-deck/tests/theme-browser-smoke.test.ts && node scripts/co-deck/tests/theme-browser-smoke.browser.mjs",
    "test:visual": "bun test scripts/co-deck/tests/theme-visual-regression.test.ts",
    "test:visual:update": "UPDATE_BASELINES=1 bun test scripts/co-deck/tests/theme-visual-regression.test.ts"
  },
  "dependencies": {
    "@pdf-lib/fontkit": "^1.1.1",
    "fflate": "^0.8.2",
    "pdf-lib": "^1.17.1"
  },
  "optionalDependencies": {
    "playwright": "^1.45.0",
    "pdf-to-png-converter": "^4.1.1"
  }
