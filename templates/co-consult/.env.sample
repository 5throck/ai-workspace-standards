# .env.sample — copy to .env and fill in values
# All variables listed here are required unless marked [optional]

# [KEY_NAME]=[description]
# Example:
# API_KEY=your_api_key_here
# DATABASE_URL=postgresql://user:password@localhost/dbname

# DART OpenAPI — Korean Financial Supervisory Service electronic disclosure system
# Issue key at: https://opendart.fss.or.kr/uss/umt/EgovMberInsertView.do
# Required for k-dart skill (financial filing lookup)
# API_K_DART=your_dart_api_key_here
