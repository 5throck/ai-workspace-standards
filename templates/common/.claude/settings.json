{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "git config core.hooksPath .githooks",
            "statusMessage": "Configuring git hooks..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bun scripts/hooks/post-write-lifecycle-check.ts"
          }
        ]
      }
    ]
  }
}
