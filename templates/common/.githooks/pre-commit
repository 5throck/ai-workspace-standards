#!/usr/bin/env bash
# pre-commit: auto-log memory + changelog, audit, secret scan.
# memory/-only commits skip documentation audit but still run secret scan.

STAGED=$(git diff --cached --name-only)
[ -z "$STAGED" ] && exit 0

# Check if this is a memory-only commit (for selective skipping)
MEMORY_ONLY=false
if ! echo "$STAGED" | grep -qv "^memory/"; then
  MEMORY_ONLY=true
fi

# ── 1. Auto-update Markdown "Last Updated" dates ──────────────────────────────
MD_STAGED=$(echo "$STAGED" | grep -i "\.md$" || true)
if [ -n "$MD_STAGED" ]; then
  TODAY=$(date +%Y-%m-%d)
  while IFS= read -r file; do
    [ -z "$file" ] && continue
    if [ -f "$file" ] && grep -q "Last Updated:" "$file"; then
      sed -i "s/Last Updated: [0-9]\{4\}-[0-9]\{2\}-[0-9]\{2\}/Last Updated: $TODAY/g" "$file"
      git add "$file"
    fi
  done <<< "$MD_STAGED"
fi

# ── 1-A. Auto-date CHANGELOG.md [Unreleased] entries ─────────────────────────
if echo "$STAGED" | grep -q "CHANGELOG.md"; then
  TODAY=$(date +%Y-%m-%d)
  perl -i -pe '
    BEGIN { $today = shift; $in_unreleased = 0; }
    if (/^## \[Unreleased\]/) { $in_unreleased = 1; }
    elsif (/^## \[/ && !/^## \[Unreleased\]/) { $in_unreleased = 0; }
    if ($in_unreleased && /^(\s*-\s+)(?!\*\*\[\d{4}-\d{2}-\d{2}\]\*\*: )/) {
      s/^(\s*-\s+)/$1**[$today]**: /;
    }
  ' "$TODAY" CHANGELOG.md
  git add CHANGELOG.md
fi


# ── 2. Block staged .env files ────────────────────────────────────────────────
if echo "$STAGED" | grep -qE "^\.env$|^\.env\.[^s]|/\.env$|/\.env\.[^s]"; then
  echo -e "\033[31m[FAIL]\033[0m Attempt to commit .env file detected."
  echo "       .env files must never be committed. Add to .gitignore and use .env.sample instead."
  exit 1
fi

# ── 3. Documentation audit ────────────────────────────────────────────────────
# Skip documentation audit for memory-only commits (workflow optimization)
if [ "$MEMORY_ONLY" = false ]; then
  bash scripts/audit.sh || exit 1
fi

# ── 3.5. Agent Lifecycle Audit ─────────────────────────────────────────────────
# Run when workspace root agent files are modified (skip sub-projects)
AGENT_FILES=$(echo "$STAGED" | grep -iE "^agents/.*\.md|^AGENTS\.md" || true)
if [ -n "$AGENT_FILES" ]; then
  echo ""
  echo "=== Agent Lifecycle Audit ==="

  if command -v bun &>/dev/null && [ -f "scripts/agent-lifecycle-audit.ts" ]; then
    # Check only workspace root agents (exclude sub-projects)
    if bun scripts/agent-lifecycle-audit.ts --json 2>/dev/null | grep -q '"errors": \[\]'; then
      echo -e "\033[32m[PASS]\033[0m Agent audit: all agents healthy"
    else
      echo -e "\033[31m[FAIL]\033[0m Agent audit detected issues — commit blocked."
      echo "       Run 'bun scripts/agent-lifecycle-audit.ts' to see details."
      echo "       Common fixes:"
      echo "       - Add frontmatter (name, role, status) to agent file"
      echo "       - Register agent in AGENTS.md"
      echo "       - Reassign skills from deprecated agents"
      exit 1
    fi
  else
    echo -e "\033[33m[SKIP]\033[0m Agent audit requires bun. Install for automated checks."
  fi
fi

# ── 3.6. Skill Lifecycle Audit ─────────────────────────────────────────────────
# Run when skill files are modified
SKILL_FILES=$(echo "$STAGED" | grep -iE "SKILL\.md|\.claude/skills/" || true)
if [ -n "$SKILL_FILES" ]; then
  echo ""
  echo "=== Skill Lifecycle Audit ==="

  if command -v bun &>/dev/null && [ -f "scripts/skill-lifecycle-audit.ts" ]; then
    if bun scripts/skill-lifecycle-audit.ts --json 2>/dev/null | grep -q '"errors": \[\]'; then
      echo -e "\033[32m[PASS]\033[0m Skill audit: all skills healthy"
    else
      echo -e "\033[31m[FAIL]\033[0m Skill audit detected issues — commit blocked."
      echo "       Run 'bun scripts/skill-lifecycle-audit.ts' to see details."
      echo "       Common fixes:"
      echo "       - Add 'owner: agent-name' to skill frontmatter"
      echo "       - Reassign orphaned skills to valid agents"
      echo "       - Archive deprecated skills to skills/_archive/"
      exit 1
    fi
  else
    echo -e "\033[33m[SKIP]\033[0m Skill audit requires bun. Install for automated checks."
  fi
fi
# ── 4. Script Parity Check ─────────────────────────────────────────────────────
# Ensure every .sh has a corresponding .ps1 and vice versa
if [ -d "scripts" ]; then
  SH_NAMES=$(ls scripts/*.sh 2>/dev/null | sed 's|.*/||; s/\.sh$//' | sort)
  PS1_NAMES=$(ls scripts/*.ps1 2>/dev/null | sed 's|.*/||; s/\.ps1$//' | sort)

  if [ "$SH_NAMES" != "$PS1_NAMES" ]; then
    echo -e "\033[31m[FAIL]\033[0m Script parity violation: .sh and .ps1 files don't match"
    echo "   Every script must have both .sh and .ps1 versions"
    echo ""
    echo "   .sh files:"
    echo "$SH_NAMES" | sed 's/^/     - /'
    echo ""
    echo "   .ps1 files:"
    echo "$PS1_NAMES" | sed 's/^/     - /'
    exit 1
  fi
fi

# ── 5. Secret scan ────────────────────────────────────────────────────────────
echo ""
echo "=== Secret scan ==="

_GITLEAKS_CONFIG=""
[ -f ".gitleaks.toml" ] && _GITLEAKS_CONFIG="--config .gitleaks.toml"

if command -v gitleaks &>/dev/null; then
  # shellcheck disable=SC2086
  if gitleaks protect --staged --no-banner --log-level error $_GITLEAKS_CONFIG; then
    echo -e "\033[32m[PASS]\033[0m gitleaks: no secrets detected"
  else
    echo -e "\033[31m[FAIL]\033[0m gitleaks detected potential secrets — commit blocked."
    echo "       Review the output above and remove secrets before committing."
    echo "       To suppress a false positive: add '# gitleaks:allow' on the same line,"
    echo "       or add an allowlist entry to .gitleaks.toml."
    exit 1
  fi
else
  STAGED_CONTENT=$(git diff --cached -U0 | grep "^+" | grep -v "^+++")
  FOUND=0

  _check() {
    local label="$1"; local pattern="$2"
    if echo "$STAGED_CONTENT" | grep -qP "$pattern" 2>/dev/null || \
       echo "$STAGED_CONTENT" | grep -qE "$pattern" 2>/dev/null; then
      echo -e "\033[31m[FAIL]\033[0m Possible secret — $label"
      FOUND=1
    fi
  }

  _check "Private key header"        "-----BEGIN (RSA |EC |DSA |OPENSSH )?PRIVATE KEY"
  _check "AWS Access Key ID"          "AKIA[0-9A-Z]{16}"
  _check "GitHub PAT (classic)"       "ghp_[0-9a-zA-Z]{36}"
  _check "GitHub PAT (fine-grained)"  "github_pat_[0-9a-zA-Z_]{82}"
  _check "OpenAI API key"             "sk-[0-9a-zA-Z]{48}"
  _check "Anthropic API key"          "sk-ant-[0-9a-zA-Z_-]{90,}"
  _check "Generic secret assignment"  "(password|passwd|secret|api_key|apikey|access_token|auth_token)[[:space:]]*=[[:space:]]*['\"][^'\"]{8,}['\"]"

  if [ "$FOUND" -eq 0 ]; then
    echo -e "\033[32m[PASS]\033[0m Regex secret scan: nothing detected"
    echo "       Tip: install gitleaks for comprehensive scanning — https://github.com/gitleaks/gitleaks"
  else
    echo ""
    echo "       Remove secrets from staged files before committing."
    echo "       Use environment variables or .env (gitignored) instead."
    exit 1
  fi
fi
