  "variantValidationPolicy": {
    "description": "Which domain checks are mandatory for new-project.sh to allow project creation",
    "mandatoryBeforeProjectCreation": ["variant", "agent", "skill"],
    "warningOnly": ["script", "readme"]
  },
  "newVariantChecklist": [
    "Create variant directory under templates/",
    "Create variant.json with name, description, status, version, lifecycle.statusSince, lifecycle.lastTransition",
    "Create agents/ directory with at least pm.md",
    "Create AGENTS.md roster",
    "Create skills/ directory with at least agent-lifecycle-manager",
    "Create .claude/commands/meeting.md (copy from templates/common)",
    "Create .gemini/commands/meeting.md (copy from templates/common)",
    "Create docs/<variant>.context.md",
    "Create README.md and README_ko.md",
    "Run validate-templates.ts --variant <name> to verify all checks pass"
  ]
}
