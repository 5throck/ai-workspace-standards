#!/usr/bin/env bash
# pre-push: run audit gate + integration tests + block direct push to main/master.

# ── 1. Audit gate ─────────────────────────────────────────────────────────────
echo "=== pre-push audit ==="
bun scripts/audit.ts || {
  echo ""
  echo -e "\033[31m❌ Audit failed — push blocked. Fix issues above before pushing.\033[0m"
  exit 1
}

# ── 2. Integration tests ──────────────────────────────────────────────────────
echo "=== pre-push integration tests ==="
if command -v node >/dev/null 2>&1; then
  echo "Running integration tests..."
  node scripts/test-runner.ts integration || {
    echo ""
    echo -e "\033[31m❌ Integration tests failed — push blocked. Fix test failures before pushing.\033[0m"
    exit 1
  }
else
  echo "⚠️  Node not found — skipping integration tests"
fi

# ── 3. Block direct push to protected branches ────────────────────────────────
BRANCH=$(git rev-parse --abbrev-ref HEAD)
if [ "$BRANCH" = "main" ] || [ "$BRANCH" = "master" ]; then
  echo ""
  echo -e "\033[31m❌ Direct push to '$BRANCH' is blocked. Use a PR branch.\033[0m"
  echo "   Create a PR with: /sync \"feat: ...\"  or  bun scripts/dev-sync.ts \"feat: ...\""
  exit 1
fi
