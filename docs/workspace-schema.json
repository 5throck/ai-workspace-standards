{
  "$schema": "https://json-schema.org/draft/2020-12",
  "version": "1.0.0",
  "description": "Single Source of Truth for workspace-wide invariants. All dependent documents must match these values. Validated by scripts/validate-templates.ts at pre-commit.",
  "workflow": {
    "phases": {
      "canonical": ["0", "1-2", "3", "4", "5", "6"],
      "count": 7,
      "pm_owned": ["0", "1-2", "5", "6"],
      "autonomous": ["1-2", "3", "4", "5"],
      "definitions": {
        "0":   "Project Initiation",
        "1-2": "Planning & Architecture",
        "3":   "Design Handoff",
        "4":   "Execution",
        "5":   "Quality Assurance",
        "6":   "Lifecycle Finalization"
      }
    }
  },
  "agent_tiers": {
    "pm":                  "high",
    "architect":           "high",
    "auditor":             "medium",
    "docs-writer":         "medium",
    "automation-engineer": "low",
    "scaffolding-expert":  "low",
    "lifecycle-manager":   "medium",
    "security-expert":     "medium"
  },
  "models": {
    "claude": {
      "high":   "claude-opus-4-7",
      "medium": "claude-sonnet-4-6",
      "low":    "claude-haiku-4-5"
    },
    "gemini": {
      "high":   "gemini-3.1-pro",
      "medium": "gemini-3.5-flash",
      "low":    "gemini-3.5-flash"
    },
    "antigravity": {
      "high":   "gemini-3.1-pro",
      "medium": "gemini-3.5-flash",
      "low":    "gemini-3.5-flash"
    },
    "gemini-cli": {
      "high":   "gemini-3.1-pro",
      "medium": "gemini-3.5-flash",
      "low":    "gemini-3.5-flash"
    }
  },
  "_notes": {
    "variant_specific": "Variant-specific phase names (e.g., co-security Phase 3 = Threat Modeling) are declared in each variant's variant.json under phases.phase3_name",
    "variant_agents": "Variant-specific agent tiers are declared in each variant's variant.json under agent_tiers"
  }
}
