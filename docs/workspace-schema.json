{
  "$schema": "https://json-schema.org/draft/2020-12",
  "version": "1.3.0",
  "description": "Single Source of Truth for workspace-wide invariants. All dependent documents must match these values. Validated by scripts/validate-templates.ts at pre-commit.",
  "workflow": {
    "phases": {
      "canonical": ["0", "1-2", "3", "4", "5", "6"],
      "count": 7,
      "pm_owned": ["0", "1-2", "5", "6"],
      "autonomous": ["1-2", "3", "4", "5"],
      "definitions": {
        "0":   "Project Initiation",
        "1-2": "Planning & Architecture",
        "3":   "Design Handoff",
        "4":   "Execution",
        "5":   "Quality Assurance",
        "6":   "Lifecycle Finalization"
      }
    }
  },
  "agent_tiers": {
    "pm":                  "high",
    "architect":           "high",
    "auditor":             "medium",
    "docs-writer":         "medium",
    "automation-engineer": "low",
    "scaffolding-expert":  "low",
    "lifecycle-manager":   "medium",
    "security-expert":     "medium"
  },
  "models": {
    "claude": {
      "high":   "claude-opus-4-7",
      "medium": "claude-sonnet-4-6",
      "low":    "claude-haiku-4-5"
    },
    "gemini": {
      "high":   "gemini-3.1-pro",
      "medium": "gemini-3.5-flash",
      "low":    "gemini-3.5-flash"
    },
    "antigravity": {
      "high":   "gemini-3.1-pro",
      "medium": "gemini-3.5-flash",
      "low":    "gemini-3.5-flash"
    },
    "gemini-cli": {
      "high":   "gemini-3.1-pro",
      "medium": "gemini-3.5-flash",
      "low":    "gemini-3.5-flash"
    }
  },
  "variant_lifecycle": {
    "description": "Governance rules for variant lifecycle transitions",
    "beta_engagement_criteria_required": true,
    "engagement_criteria_schema": {
      "evaluation_start": "YYYY-MM-DD",
      "evaluation_period_days": 14,
      "green_threshold": "description of success condition",
      "yellow_action": "action if no engagement within period",
      "red_trigger": "condition for immediate beta cancellation",
      "current_status": "green|yellow|red"
    }
  },
  "_notes": {
    "variant_specific": "Variant-specific phase names (e.g., co-security Phase 3 = Threat Modeling) are declared in each variant's variant.json under phases.phase3_name",
    "variant_agents": "Variant-specific agent tiers are declared in each variant's variant.json under agent_tiers"
  },
  "i18n": {
    "description": "Internationalization policy. locale_codes defines all language codes recognized as valid translation zones. Files inside <lang-code>/ or locales/<lang-code>/ directories are exempt from the English-only documentation rule.",
    "locale_codes": ["ko", "ja", "zh-CN", "zh-TW", "de", "es", "fr", "pt", "vi", "ms", "id", "th", "ru", "it", "ar"],
    "translation_zone_patterns": [
      "<lang-code>/",
      "locales/<lang-code>/"
    ],
    "note": "audit.ts and validate-md-language.ts must read locale_codes from this file — do NOT hardcode language codes in scripts."
  },
  "rootAllowlist": {
    "description": "Whitelist of files and directories permitted in the workspace root. Anything not in these lists triggers a stray-artifact audit failure.",
    "files": [
      ".git",
      "package.json",
      "package-lock.json",
      "bun.lockb",
      "bun.lock",
      "tsconfig.json",
      ".gitignore",
      ".gitattributes",
      ".gitmodules",
      ".editorconfig",
      ".gitleaks.toml",
      "README.md",
      "README_ko.md",
      "CLAUDE.md",
      "GEMINI.md",
      "AGENTS.md",
      "CHANGELOG.md",
      "CONSTITUTION.md",
      "SECURITY.md",
      "LICENSE",
      ".mcp.json",
      ".sync_context.tmp",
      "propagation-map.json",
      "fix.mjs",
      ".DS_Store"
    ],
    "dirs": [
      ".git",
      "scripts",
      "tests",
      "agents",
      "skills",
      "docs",
      "memory",
      "templates",
      ".claude",
      ".gemini",
      ".githooks",
      ".git",
      "node_modules",
      ".antigravitycli",
      ".codegraph",
      ".codex",
      ".github",
      "Projects"
    ]
  }
}
