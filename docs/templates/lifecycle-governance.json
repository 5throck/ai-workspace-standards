{
  "version": "1.2.0",
  "lastUpdated": "2026-06-13",
  "status": "stable",
  "description": "Lifecycle governance for the workspace — covers all layers (workspace-root, templates-common, templates-variants, l2-projects). SSOT referenced by validate-templates.ts and audit.ts.",
  "layers": {
    "workspace-root": {
      "orchestrator": "scripts/audit.ts",
      "domains": {
        "variant": { "applicable": false },
        "agent": { "applicable": true, "tool": "scripts/agent-lifecycle-audit.ts", "mandatory": true, "currentStatus": "active" },
        "skill": { "applicable": true, "tool": "scripts/skill-lifecycle-audit.ts", "mandatory": true, "currentStatus": "active" },
        "script": { "applicable": true, "tool": "scripts/verify-scripts.ts", "mandatory": true, "currentStatus": "active" },
        "readme": { "applicable": true, "tool": "scripts/readme-lifecycle-audit.ts", "mandatory": true, "currentStatus": "active" }
      }
    },
    "templates-common": {
      "orchestrator": "scripts/validate-templates.ts (checkGovernance)",
      "domains": {
        "variant": { "applicable": true, "tool": "common.lifecycle.json", "mandatory": true, "currentStatus": "active" },
        "agent": { "applicable": false },
        "skill": { "applicable": false },
        "script": { "applicable": true, "tool": "scripts/verify-scripts.ts (L0/L1 drift)", "mandatory": true, "currentStatus": "active" },
        "readme": { "applicable": true, "tool": "scripts/readme-lifecycle-audit.ts", "mandatory": true, "currentStatus": "active" }
      }
    },
    "templates-variants": {
      "orchestrator": "scripts/validate-templates.ts",
      "domains": {
        "variant": { "applicable": true, "tool": "scripts/validate-templates.ts (checkVariantManifests)", "mandatory": true, "currentStatus": "active" },
        "agent": { "applicable": true, "tool": "scripts/validate-templates.ts (checkAgents, checkAgentsRoster)", "mandatory": true, "currentStatus": "active" },
        "skill": { "applicable": true, "tool": "scripts/validate-templates.ts (checkVariantSkills)", "mandatory": true, "currentStatus": "active" },
        "script": { "applicable": true, "tool": "scripts/verify-scripts.ts", "mandatory": false, "currentStatus": "partial" },
        "readme": { "applicable": true, "tool": "scripts/validate-templates.ts (checkReadmePresence)", "mandatory": true, "currentStatus": "active" }
      }
    },
    "l2-projects": {
      "orchestrator": "scripts/audit.ts (project copy)",
      "domains": {
        "variant": { "applicable": false },
        "agent": { "applicable": true, "tool": "scripts/agent-lifecycle-audit.ts", "mandatory": true, "currentStatus": "active" },
        "skill": { "applicable": true, "tool": "scripts/skill-lifecycle-audit.ts", "mandatory": true, "currentStatus": "active" },
        "script": { "applicable": true, "tool": "scripts/verify-scripts.ts", "mandatory": false, "currentStatus": "gap" },
        "readme": { "applicable": true, "tool": "scripts/readme-lifecycle-audit.ts", "mandatory": false, "currentStatus": "gap" }
      }
    }
  },
  "variantValidationPolicy": {
    "description": "Which domain checks are mandatory for new-project.ts to allow project creation",
    "mandatoryBeforeProjectCreation": ["variant", "agent", "skill"],
    "warningOnly": ["script", "readme"]
  },
  "newVariantChecklist": [
    "Create variant directory under templates/",
    "Create variant.json with name, description, status, version, lifecycle.statusSince, lifecycle.lastTransition",
    "Create agents/ directory with at least pm.md",
    "Create AGENTS.md roster",
    "Create skills/ directory with at least agent-lifecycle-manager",
    "Create .claude/commands/meeting.md (copy from templates/common)",
    "Create .gemini/commands/meeting.md (copy from templates/common)",
    "Create docs/<variant>.context.md",
    "Create README.md and README_ko.md",
    "Run validate-templates.ts --variant <name> to verify all checks pass"
  ],
  "history": [
    {
      "date": "2026-05-28",
      "event": "initial",
      "note": "Lifecycle governance established for templates/common at v1.0.0"
    },
    {
      "date": "2026-05-30",
      "event": "pm-merge-migration",
      "note": "Updated for frontmatter merge migration - governance inheritance confirmed"
    },
    {
      "date": "2026-06-02",
      "event": "governance-tool-expansion",
      "note": "validate-templates.ts v1.4.0: 4 new check functions added (VA-01, VA-02, VA-03, WS-03); new-project scripts now invoke post-scaffolding variant validation"
    },
    {
      "date": "2026-06-03",
      "event": "co-consult-variant-added",
      "note": "co-consult variant added at v1.0.0 stable. 13 variant-specific skills created."
    },
    {
      "date": "2026-06-13",
      "event": "ssot-consolidation",
      "note": "Merged docs/governance/lifecycle-governance.json (v1.2.0) into this SSOT. Added workspace-root, templates-common, l2-projects layer definitions. docs/governance/ version deleted."
    }
  ]
}
