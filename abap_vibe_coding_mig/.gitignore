# ============================================================
# Override parent C:\git\.gitignore /*/ pattern
# This project needs to track its own files
# ============================================================
!/*
!*/**

# Secrets — never commit (must come AFTER !/* to take effect)
.env
.env.*

# Python
.venv/
__pycache__/
*.pyc
*.pyo
dist/
*.egg-info/

# Node.js
node_modules/
.next/
dist/
build/

# OS artifacts
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp

# Local AI settings (personal overrides — never shared)
.claude/settings.local.json
.gemini/settings.local.json
.mcp.local.json

# Crypto / certificates — never commit private key material
*.pem
*.key
*.p12
*.pfx
*.cer
*.crt
*.der
*.jks
*.keystore

# Temp / build artifacts
*.log
*.bak
*.tmp

# Databases
*.sqlite
*.db

# CodeGraph Index
.codegraph/

# Prevent .cmd files (use .sh/.ts or .ps1 instead)
*.cmd
