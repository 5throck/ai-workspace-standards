# EditorConfig — https://editorconfig.org
# Workspace-level defaults — apply to all files in C:\git\ and subdirectories.
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
insert_final_newline = true

[*.py]
indent_size = 4

[*.md]
trim_trailing_whitespace = false   # trailing spaces = intentional line break in Markdown

[*.{ps1,psm1}]
end_of_line = crlf                 # PowerShell scripts work best with CRLF on Windows

[Makefile]
indent_style = tab

[*.{yaml,yml}]
indent_size = 2

[*.json]
indent_size = 2
